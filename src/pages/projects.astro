---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Projects" pageDesc="Some of my projects and works.">
    <div class="space-y-8">
      <!-- Tippy Mod Project -->
      <article class="border-border border-b pb-8">
        <h2 class="text-2xl font-semibold mb-2">
          <a href="https://modrinth.com/mod/tippy" target="_blank" class="hover:text-accent transition-colors">
            Tippy Mod
          </a>
        </h2>
        <p class="mb-4 text-muted-foreground">
          A handy Minecraft mod that adds customizable tips functionality to enhance your gameplay experience. 
          With Tippy, you can get detailed information about items, blocks, and entities.
        </p>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="bg-accent/10 text-accent px-3 py-1 rounded-full text-sm">Minecraft</span>
          <span class="bg-accent/10 text-accent px-3 py-1 rounded-full text-sm">Java</span>
          <span class="bg-accent/10 text-accent px-3 py-1 rounded-full text-sm">Forge</span>
          <span class="bg-accent/10 text-accent px-3 py-1 rounded-full text-sm">Mixin</span>
        </div>
        <div class="flex gap-4">
          <a 
            href="https://modrinth.com/mod/tippy" 
            target="_blank"
            class="inline-flex items-center gap-2 text-accent hover:underline"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            Download on Modrinth
          </a>
          <a 
            href="https://github.com/song682/Tippy" 
            target="_blank"
            class="inline-flex items-center gap-2 text-accent hover:underline"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
      </article>

      <!-- Placeholder for future projects -->
      <article class="border-border border-b pb-8 opacity-60">
        <h2 class="text-2xl font-semibold mb-2">More Projects Coming Soon</h2>
        <p class="text-muted-foreground">
          I'm always working on something new. Check back later for more projects!
        </p>
      </article>
    </div>
  </Main>
  <Footer />
</Layout>
