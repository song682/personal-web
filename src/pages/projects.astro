---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/layouts/Main.astro";
import { SITE } from "@/config";
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import ProjectLogo from "@/components/ProjectLogo.astro";
import StageBadge from "@/components/StageBadge.astro";
import ProjectLinks from "@/components/ProjectLinks.astro";

/* ========== Types ========== */

type Stage = "Pre-Alpha" | "Alpha" | "Beta" | "Release" | "Maintained" | "Archived";

type LinkType = "curseforge" | "modrinth" | "source" | "link";

interface ProjectLink {
  href: string;
  label: string;
  type?: LinkType;
}

interface Project {
  name: string;
  description: string;
  tags: string[];
  links: ProjectLink[];
  logo?: ImageMetadata;
  logoSize?: number | [number, number];
  banner?: ImageMetadata;
  stage: Stage;
}

/* ========== Helpers ========== */

const DEFAULT_LOGO_SIZE = 64;

function getLogoWH(size: number | [number, number] = DEFAULT_LOGO_SIZE) {
  if (Array.isArray(size)) return { w: size[0], h: size[1] };
  return { w: size, h: size };
}

function truncateDesc(text: string, maxLen = 60): string {
  if (text.length <= maxLen) return text;
  return text.slice(0, maxLen).trimEnd() + "...";
}

/** Parse "64*35"-style string to [w, h]; plain number stays as-is */
function parseLogoSize(size: number | string | undefined): number | [number, number] | undefined {
  if (size === undefined) return undefined;
  if (typeof size === "number") return size;
  const parts = size.split("*");
  if (parts.length === 2) return [Number(parts[0]), Number(parts[1])];
  return Number(size) || undefined;
}

/** Transform content-collection links (Record<string,string>[]) into ProjectLink[] */
const LINK_LABELS: Record<string, string> = {
  curseforge: "CurseForge",
  modrinth: "Modrinth",
  source: "Source",
  link: "Link",
};

function parseLinks(raw: Record<string, string>[]): ProjectLink[] {
  return raw.map(item => {
    const [type, url] = Object.entries(item)[0];
    return { href: url, label: LINK_LABELS[type] ?? type, type: type as LinkType };
  });
}

/* ========== Data ========== */

const rawProjects = await getCollection("projects");

const projects: Project[] = rawProjects.map(p => ({
  name: p.data.title,
  description: p.data.description,
  tags: p.data.tags,
  links: parseLinks(p.data.links),
  logo: p.data.logo,
  logoSize: parseLogoSize(p.data["logo-size"]),
  banner: p.data.banner,
  stage: p.data.stage,
}));
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Projects" pageDesc="Some of my projects and works.">
    <!-- ========== View Toggle ========== -->
    <div class="mb-6 flex justify-end">
      <button
        id="view-toggle"
        class="bg-card-bg hover:bg-border inline-flex cursor-pointer items-center gap-2 rounded-lg border border-border px-3 py-2 text-sm transition-colors"
        title="Toggle view mode"
        aria-label="Toggle between list and card view"
      >
        <svg
          id="toggle-icon-list"
          class="hidden h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="8" y1="6" x2="21" y2="6" />
          <line x1="8" y1="12" x2="21" y2="12" />
          <line x1="8" y1="18" x2="21" y2="18" />
          <line x1="3" y1="6" x2="3.01" y2="6" />
          <line x1="3" y1="12" x2="3.01" y2="12" />
          <line x1="3" y1="18" x2="3.01" y2="18" />
        </svg>
        <svg
          id="toggle-icon-grid"
          class="hidden h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <rect x="3" y="3" width="7" height="7" />
          <rect x="14" y="3" width="7" height="7" />
          <rect x="3" y="14" width="7" height="7" />
          <rect x="14" y="14" width="7" height="7" />
        </svg>
        <span id="toggle-label">List</span>
      </button>
    </div>

    <!-- ============ LIST VIEW ============ -->
    <div id="list-view" class="space-y-8">
      {
        projects.map((project) => (
          <article class="animate-fade-in flex flex-row items-start gap-6 border-b border-border pb-8">
            <!-- Left: content -->
            <div class="min-w-0 flex-1">
              <h2 class="mb-2 text-2xl font-semibold">{project.name}</h2>
              <p class="text-muted-foreground mb-4">{project.description}</p>
              <div class="mb-4 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="bg-accent/10 text-accent rounded-full px-3 py-1 text-sm">
                    {tag}
                  </span>
                ))}
              </div>
              <ProjectLinks links={project.links} />
            </div>

            <!-- Right: logo + stage badge -->
            <div class="flex flex-shrink-0 flex-col items-center gap-2">
              <ProjectLogo
                logo={project.logo}
                logoSize={project.logoSize}
              />
              <StageBadge stage={project.stage} />
            </div>
          </article>
        ))
      }

      <!-- List placeholder -->
      <article class="border-b border-border pb-8 opacity-60">
        <h2 class="mb-2 text-2xl font-semibold">More Projects Coming Soon</h2>
        <p class="text-muted-foreground">
          I'm always working on something new. Check back later for more projects!
        </p>
      </article>
    </div>

    <!-- ============ CARD VIEW ============ -->
    <div id="card-view" class="hidden">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {
          projects.map((project) => {
            const { h: logoH } = getLogoWH(project.logoSize);
            const shortDesc = truncateDesc(project.description);
            return (
              <article class="animate-fade-in relative overflow-hidden rounded-xl border border-border aspect-[5/3]">
                {/* Banner: top 1/3 */}
                <div class="absolute top-0 left-0 right-0 h-1/3 bg-card-banner">
                  {
                    project.banner ? (
                      <img
                        src={project.banner.src}
                        alt=""
                        class="h-full w-full object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <div class="h-full w-full bg-card-banner"></div>
                    )
                  }
                </div>

                {/* Info: bottom 2/3, gradient at top */}
                <div
                  class="absolute top-1/3 left-0 right-0 bottom-0 flex flex-col items-start pl-[10px] pr-[15px] pb-3"
                  style="background: linear-gradient(to bottom, transparent 0%, var(--card-solid) 10%, var(--card-solid) 100%)"
                >
                  {/* Logo straddles the 1/3 boundary */}
                  <div style={`margin-top:-${logoH / 2}px;`}>
                    <ProjectLogo
                      logo={project.logo}
                      logoSize={project.logoSize}
                    />
                  </div>

                  {/* Title row with stage badge, 10px below logo */}
                  <div
                    class="mt-[10px] flex w-full items-start justify-between gap-2"
                  >
                    <h3 class="text-base font-semibold leading-tight">
                      {project.name}
                    </h3>
                    <StageBadge stage={project.stage} class="ml-auto" />
                  </div>

                  {/* Description (truncated) */}
                  <p class="text-muted-foreground mt-1 text-xs leading-relaxed">
                    {shortDesc}
                  </p>

                  {/* Tags */}
                  <div class="mt-2 flex flex-wrap justify-center gap-1">
                    {project.tags.map((tag) => (
                      <span class="bg-accent/10 text-accent rounded-full px-2 py-0.5 text-[10px]">
                        {tag}
                      </span>
                    ))}
                  </div>

                  {/* Links */}
                  <div class="mt-auto pt-2">
                    <ProjectLinks links={project.links} />
                  </div>
                </div>
              </article>
            )
          })
        }

        {/* Card placeholder */}
        <article class="relative overflow-hidden rounded-xl border border-dashed border-border bg-card-bg/50 aspect-[5/3] opacity-60">
          <div class="flex h-full flex-col items-center justify-center p-4 text-center">
            <svg
              class="mb-2 h-8 w-8 text-muted-foreground"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M12 5v14M5 12h14" />
            </svg>
            <h3 class="text-sm font-semibold">More Projects</h3>
            <p class="text-muted-foreground mt-1 text-xs">Coming soon!</p>
          </div>
        </article>
      </div>
    </div>
  </Main>
  <Footer />
</Layout>

<script>
  const STORAGE_KEY = "projects-view-mode";
  const LIST_VIEW_ID = "list-view";
  const CARD_VIEW_ID = "card-view";

  function getViewMode(): string {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === "list" || stored === "card") return stored;
    return "list";
  }

  function applyView(mode: string) {
    const listView = document.getElementById(LIST_VIEW_ID);
    const cardView = document.getElementById(CARD_VIEW_ID);
    const toggleIconList = document.getElementById("toggle-icon-list");
    const toggleIconGrid = document.getElementById("toggle-icon-grid");
    const toggleLabel = document.getElementById("toggle-label");

    if (!listView || !cardView) return;

    if (mode === "card") {
      listView.classList.add("hidden");
      cardView.classList.remove("hidden");
      toggleIconList?.classList.remove("hidden");
      toggleIconGrid?.classList.add("hidden");
      if (toggleLabel) toggleLabel.textContent = "List";
    } else {
      listView.classList.remove("hidden");
      cardView.classList.add("hidden");
      toggleIconList?.classList.add("hidden");
      toggleIconGrid?.classList.remove("hidden");
      if (toggleLabel) toggleLabel.textContent = "Card";
    }
  }

  function setupToggle() {
    const toggleBtn = document.getElementById("view-toggle");
    if (!toggleBtn) return;

    const currentMode = getViewMode();
    applyView(currentMode);

    toggleBtn.addEventListener("click", () => {
      const newMode = getViewMode() === "list" ? "card" : "list";
      localStorage.setItem(STORAGE_KEY, newMode);
      applyView(newMode);
    });
  }

  setupToggle();
  document.addEventListener("astro:after-swap", setupToggle);
</script>
