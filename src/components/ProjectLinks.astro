---
type LinkType = "curseforge" | "modrinth" | "source" | "link";

interface ProjectLink {
  href: string;
  label: string;
  type?: LinkType;
}

interface Props {
  links: ProjectLink[];
  class?: string;
}

const { links, class: className } = Astro.props;
---

<div class:list={["flex flex-wrap gap-2", className]}>
  {
    links.map((link) => {
      const linkType = link.type ?? "link";
      return (
        <a
          href={link.href}
          target="_blank"
          class="bg-card-bg hover:bg-border inline-flex items-center gap-1.5 rounded-lg border border-border px-3 py-1.5 text-xs transition-colors"
        >
          {
            linkType === "curseforge" ? (
              <!-- CurseForge flame icon -->
              <svg
                class="h-3.5 w-3.5 text-orange-500"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M12 2c-1.5 3-3.5 6-3.5 8.5C8.5 12.4 10.1 14 12 14s3.5-1.6 3.5-3.5C15.5 8 13 5 12 2zm-2 12c0 1.1.9 2 2 2s2-.9 2-2c0-.5-.2-1.1-.5-1.7L12 14l-1.5-1.7c-.3.6-.5 1.2-.5 1.7z" />
              </svg>
            ) : linkType === "modrinth" ? (
              <!-- Modrinth icon -->
              <svg
                class="h-3.5 w-3.5 text-green-500"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M12 2L2 8v8l10 6 10-6V8L12 2zm0 3l7 4v6l-7 5-7-5V9l7-4z" />
              </svg>
            ) : linkType === "source" ? (
              <!-- GitHub icon -->
              <svg
                class="h-3.5 w-3.5"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
            ) : (
              <!-- External link icon -->
              <svg
                class="h-3.5 w-3.5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
            )
          }
          {link.label}
        </a>
      );
    })
  }
</div>
