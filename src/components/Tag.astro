---
type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "inline-flex items-center px-3 py-1 rounded-full bg-accent/10 text-accent hover:bg-accent hover:text-white transition-all",
      { "text-xs": size === "sm" },
      { "text-sm": size === "lg" },
    ]}
  >
    #{tagName}
  </a>
</li>
